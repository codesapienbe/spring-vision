# vLLM Module Configuration Example
# Enable or disable the vLLM backend
spring.vision.vllm.enabled=true

# vLLM API server URL
spring.vision.vllm.base-url=http://localhost:8000

# Model name (e.g., ibm-granite/granite-3.2-8b-instruct)
spring.vision.vllm.model=ibm-granite/granite-3.2-8b-instruct

# Request timeout
spring.vision.vllm.timeout=60s

# Maximum tokens to generate
spring.vision.vllm.max-tokens=512

# Temperature for sampling (0.0 - 2.0)
spring.vision.vllm.temperature=0.7

# Top-p sampling parameter
spring.vision.vllm.top-p=0.9

# Confidence threshold (0.0 - 1.0)
spring.vision.vllm.confidence-threshold=0.7

# Enable streaming responses
spring.vision.vllm.enable-streaming=false
io.github.codesapienbe.springvision.vllm.config.VllmAutoConfiguration

